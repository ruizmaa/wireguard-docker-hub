# Basic example .env file for Firefly III
# Copy this to .env and edit the values as needed
# Check the official documentation for more info:
# https://raw.githubusercontent.com/firefly-iii/firefly-iii/main/.env.example

# -----
#  App
# -----
APP_ENV=production
APP_KEY=CHANGE_ME_32_ALPHANUMERIC_CHARS    # head /dev/urandom | LC_ALL=C tr -dc 'A-Za-z0-9' | head -c 32 && echo
# SITE_OWNER=mail@example.com              # Your email address

# ---------------------
#  Timezone & language
# ---------------------
TZ=Etc/UTC  # <your_time_zone>
DEFAULT_LANGUAGE=en_US
# DEFAULT_LOCALE=es_US                     # Optional, defaults to DEFAULT_LANGUAGE

# ----------------------------
#          Database
#  must match .firefly.db.env
# ----------------------------
DB_CONNECTION=pgsql
DB_HOST=firefly_db
DB_PORT=5432
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=CHANGE_ME

# ----------------
#  Cron job token
# ----------------
# Must be a 32-character alphanumeric string
STATIC_CRON_TOKEN=abc123abc123abc123abc123abc123ab

# ---------------
#  Reverse proxy
# ---------------
TRUSTED_PROXIES=                           # Set to ** if using reverse proxy
COOKIE_SECURE=false                        # Set to true if using HTTPS
APP_URL=http://localhost:8081              # Change to your real URL

# -----
#  Map
# -----
# MAP_DEFAULT_LAT=51.983333
# MAP_DEFAULT_LONG=5.916667
# MAP_DEFAULT_ZOOM=6
